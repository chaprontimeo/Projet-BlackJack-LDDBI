def calculer_score(joueur):
    score = 0
    nombre_as = 0
    for carte in joueur:
        if carte == "As":
            score += 11
            nombre_as += 1
        elif carte in ["2","3","4","5","6","7","8","9","10"]:
            score += int(carte)
        elif carte in ["Valet","Reinne","Roi"]:
            score += 10
    while score > 21 and nombre_as > 0:
        score -= 10
        nombre_as -= 1
    return score

def brule(joueur):
    est_brule = False
    if calculer_score(joueur) > 21:
        est_brule = True
    return est_brule

